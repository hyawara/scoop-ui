{
  "name": "scoop-ui",
  "type": "module",
  "version": "1.2.2",
  "description": "A modern GUI for Scoop package manager on Windows, built with Electron and Vue 3",
  "main": "dist/main/index.js",
  "scripts": {
    "dev": "vite",
    "build:main": "tsc -p tsconfig.node.json && node scripts/copy-config.mjs",
    "build:renderer": "vite build",
    "build:icons": "node scripts/build-icons.cjs",
    "build": "npm run build:icons && npm run build:main && npm run build:renderer",
    "preview": "vite preview",
    "electron:dev": "npm run build && electron .",
    "electron:build": "npm run build && electron-builder --publish never && node scripts/cleanup-release.mjs",
    "release": "npm run build && electron-builder --publish always"
  },
  "keywords": [
    "scoop",
    "package-manager",
    "electron",
    "vue3",
    "windows"
  ],
  "author": "hyawara",
  "license": "MIT",
  "dependencies": {
    "@vicons/ionicons5": "^0.13.0",
    "electron-updater": "^6.8.9",
    "iconv-lite": "^0.7.2",
    "naive-ui": "^2.44.1",
    "pinia": "^3.0.4",
    "vue": "^3.5.39"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.3.2",
    "@types/node": "^26.1.0",
    "@vitejs/plugin-vue": "^6.0.7",
    "autoprefixer": "^10.5.2",
    "electron": "^43.0.0",
    "electron-builder": "^26.15.3",
    "png-to-ico": "^3.0.1",
    "postcss": "^8.5.16",
    "sharp": "^0.35.3",
    "tailwindcss": "^4.3.2",
    "typescript": "^6.0.3",
    "vite": "^8.1.0",
    "vue-tsc": "^3.3.5"
  }
}
